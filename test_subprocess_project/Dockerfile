# Generated by Reciper static analyzer with apt package support
# Dockerfile for conda environment with system dependencies

FROM continuumio/miniconda3:latest

# Set working directory
WORKDIR /app

# Update package lists and install system dependencies
# Install system packages via apt
RUN apt-get update && \
    apt-get install -y --no-install-recommends multiqc samtools && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Copy environment.yml (if exists)
COPY environment.yml .

# Update conda environment
# Install conda packages
RUN conda install -y pathlib

# Set default command
CMD ["/bin/bash"]
